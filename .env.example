# Copy to .env and fill values for local development
# For Streamlit Cloud, set these in the app's Secrets/Environment settings

# Postgres connection (optional for demo)
DATABASE_URL=postgresql://user:password@host:5432/langgraph_memory

# API keys
TAVILY_API_KEY=your_tavily_api_key_here
AVIATIONSTACK_API_KEY=your_aviationstack_api_key_here

# Demo mode: set to true to run without DB/LLM dependencies
DEMO_MODE=true
DATABASE_URL=postgresql://username:password@localhost:5432/langgraph_memory
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
AVIATIONSTACK_API_KEY=your_aviationstack_api_key_here
